# Local development configuration
PG_URL=postgresql://postgres:PASSWORD@localhost:5433/finsight
AUTH_PG_URL=postgresql://postgres:PASSWORD@localhost:5433/authenticate
REDIS_URL=redis://localhost:6379/0
GROQ_API_KEY=your_groq_api_key_here
AGNO_MODEL=groq:llama-3.3-70b-versatile
MEMORY_MODEL=groq:llama-3.1-8b-instant
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=finsight-task-queue
TEMPORAL_ENABLED=false
JWT_SECRET_KEY=your_jwt_secret_key_here
